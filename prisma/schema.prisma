generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ===== Application Models =====

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  matchPredictions    MatchPrediction[]
  phasePredictions    PhasePrediction[]
  championPrediction  ChampionPrediction?
}

model Team {
  id       String @id @default(cuid())
  name     String
  code     String @unique // BRA, ARG, etc.
  groupLabel String // A, B, C, ..., L
  flagUrl  String @default("")

  homeMatches  Match[] @relation("HomeTeam")
  awayMatches  Match[] @relation("AwayTeam")
  phasePredictions PhasePrediction[]
  championOf   ChampionPrediction[] @relation("Champion")
  runnerUpOf   ChampionPrediction[] @relation("RunnerUp")
  thirdPlaceOf ChampionPrediction[] @relation("ThirdPlace")
}

model Match {
  id         String  @id @default(cuid())
  phase      String  // GROUP, ROUND_32, ROUND_16, QUARTERS, SEMIS, THIRD_PLACE, FINAL
  groupLabel String? // A-L for group phase, null for knockout
  matchOrder Int     // chronological order for deadlines

  homeTeamId String?
  awayTeamId String?
  homeTeam   Team?   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team?   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeScore  Int?    // actual score, set by admin
  awayScore  Int?    // actual score, set by admin

  matchDate  DateTime
  status     String   @default("SCHEDULED") // SCHEDULED, LIVE, FINISHED

  predictions MatchPrediction[]

  @@index([phase])
  @@index([matchDate])
}

model MatchPrediction {
  id        String @id @default(cuid())
  userId    String
  matchId   String
  homeScore Int
  awayScore Int
  points    Int?   // calculated after match ends

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model PhasePrediction {
  id      String  @id @default(cuid())
  userId  String
  teamId  String
  phase   String  // ROUND_32, ROUND_16, QUARTERS, SEMIS, FINAL
  correct Boolean? // null until phase resolved
  points  Int?     // calculated when resolved

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId, phase])
  @@index([userId])
  @@index([phase])
}

model ChampionPrediction {
  id               String @id @default(cuid())
  userId           String @unique
  championTeamId   String
  runnerUpTeamId   String
  thirdPlaceTeamId String

  championPoints   Int? // 25 if correct
  runnerUpPoints   Int? // 20 if correct
  thirdPlacePoints Int? // 15 if correct

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  champion   Team @relation("Champion", fields: [championTeamId], references: [id])
  runnerUp   Team @relation("RunnerUp", fields: [runnerUpTeamId], references: [id])
  thirdPlace Team @relation("ThirdPlace", fields: [thirdPlaceTeamId], references: [id])
}

model Settings {
  key   String @id
  value String
}
